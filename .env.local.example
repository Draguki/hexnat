# ─────────────────────────────────────────────────────────────
# HexNeedle Analytics — Environment Variables
# ─────────────────────────────────────────────────────────────
#
# LOCAL DEV: copy this file to .env.local and fill in the values.
# PRODUCTION: add these same variables in the Vercel dashboard:
#   Project → Settings → Environment Variables
#
# NEVER commit .env.local to git. It is already in .gitignore.
# ─────────────────────────────────────────────────────────────

# ── Supabase (server-side only) ───────────────────────────────
# Found at: Supabase → Project → Settings → API

# Your project URL  e.g. https://abcdefghijkl.supabase.co
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Service role key — has full DB access, bypasses RLS.
# NEVER expose this in client-side code or NEXT_PUBLIC_ variables.
SUPABASE_SERVICE_KEY=eyJ...your_service_role_key_here...

# ── Supabase (client-side — safe to expose) ──────────────────
# The NEXT_PUBLIC_ prefix makes these available in the browser.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your_anon_public_key_here...

# ── CORS ─────────────────────────────────────────────────────
# The exact origin of the site that will call /api/track.
# Must match the Origin header browsers send — include protocol,
# no trailing slash.
ALLOWED_ORIGIN=https://www.hexneedle.com
